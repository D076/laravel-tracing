{
  "name": "d076/laravel-tracing",
  "description": "Tracing module for laravel",
  "keywords": ["laravel", "tracing"],
  "type": "library",
  "authors": [
    {
      "name": "Dmitry Titov",
      "email": "dezmond076@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "illuminate/bus": "^11.0|^12.0|^13.0",
    "illuminate/console": "^11.0|^12.0|^13.0",
    "illuminate/contracts": "^11.0|^12.0|^13.0",
    "illuminate/database": "^11.0|^12.0|^13.0",
    "illuminate/http": "^11.0|^12.0|^13.0",
    "illuminate/queue": "^11.0|^12.0|^13.0",
    "illuminate/routing": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "pestphp/pest": "^3.0"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "D076\\Tracing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "D076\\Tracing\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "D076\\Tracing\\Providers\\TracingServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}