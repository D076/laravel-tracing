# Keep released package lean — exclude dev-only files from `composer require` dist archives
/.github                     export-ignore
/benchmarks                  export-ignore
/phpbench.json               export-ignore
/phpstan.neon                export-ignore
/.gitattributes              export-ignore
/.gitignore                  export-ignore
/.idea                       export-ignore
/tests                       export-ignore
/phpunit.xml                 export-ignore
/resources/.gitignore        export-ignore
/resources/README.md         export-ignore
/resources/css               export-ignore
/resources/js                export-ignore
/resources/package.json      export-ignore
/resources/package-lock.json export-ignore
/resources/postcss.config.js export-ignore
/resources/tailwind.config.js export-ignore
/resources/vite.config.js    export-ignore
